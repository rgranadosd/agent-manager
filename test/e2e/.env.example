# Copy to .env and fill in. The Makefile sources test/e2e/.env automatically.
# Every value below has a default (shown) that matches the quick-start install,


# --- Endpoints ---
AMP_API_BASE_URL=http://localhost:9000
TRACES_OBSERVER_BASE_URL=http://localhost:9098

# --- Auth (OAuth2 client credentials) ---
IDP_TOKEN_URL=http://thunder.amp.localhost:8080/oauth2/token
IDP_CLIENT_ID=amp-api-client
IDP_CLIENT_SECRET=amp-api-client-secret

# --- Target org/project/environment ---
DEFAULT_ORG=default
DEFAULT_PROJECT=default
DEFAULT_ENV=default

# --- Timeouts ---
READINESS_TIMEOUT=5m

# --- LLM keys ---
OPENAI_API_KEY=        # REQUIRED: builds/invokes the IT helpdesk agents
TAVILY_API_KEY=        # optional: only for agents that use Tavily
