{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@agent-management-platform/shared-component": ["../../libs/shared-component/src"],
      "@agent-management-platform/shared-component/*": ["../../libs/shared-component/src/*"],
      "@agent-management-platform/views": ["../../libs/views/src"],
      "@agent-management-platform/views/*": ["../../libs/views/src/*"],
      "@agent-management-platform/api-client": ["../../libs/api-client/src"],
      "@agent-management-platform/api-client/*": ["../../libs/api-client/src/*"],
      "@agent-management-platform/types": ["../../libs/types/src"],
      "@agent-management-platform/types/*": ["../../libs/types/src/*"]
    },
    "ignoreDeprecations": "5.0",
    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": false,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "declaration": true,
    "types": ["jest", "node"],
    "esModuleInterop": true,
    "outDir": "dist",
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src", ".storybook", "vite.config.ts", "setupTests.tsx"],
  "exclude": [
    "src/**/__docs__",
    "src/**/__test__",
    "node_modules",
    "dist",
    "scripts"
  ]
}
