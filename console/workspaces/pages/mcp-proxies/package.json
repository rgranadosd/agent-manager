{
  "name": "@agent-management-platform/mcp-proxies",
  "version": "1.0.0",
  "type": "module",
  "types": "dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "/dist"
  ],
  "scripts": {
    "format": "prettier --write --parser typescript '**/*.{ts,tsx}'",
    "lint": "eslint --config ./eslint.config.js",
    "clean": "rm -rf dist",
    "copy-assets": "find src -type f \\( -name '*.css' -o -name '*.scss' -o -name '*.less' -o -name '*.woff*' -o -name '*.ttf' -o -name '*.eot' -o -name '*.png' \\) -exec sh -c 'mkdir -p dist/$(dirname {}| sed \"s|^src||\") && cp {} dist/$(dirname {}| sed \"s|^src||\")/$(basename {})' \\;",
    "build": "rushx clean && tsc -project tsconfig.lib.json && rushx copy-assets",
    "dev": "rushx clean && rushx copy-assets && tsc -project tsconfig.lib.json --watch"
  },
  "keywords": ["ai", "agents", "page", "react"],
  "author": "",
  "license": "Apache-2.0",
  "description": "A page component for MCP Proxy management",
  "dependencies": {
    "react-dom": "19.1.1",
    "react-router-dom": "6.28.0",
    "@mui/material": "7.0.0",
    "@emotion/react": "11.13.5",
    "@emotion/styled": "11.13.5",
    "@wso2/oxygen-ui": "0.10.1",
    "@wso2/oxygen-ui-icons-react": "0.10.1",
    "@agent-management-platform/views": "workspace:*",
    "@agent-management-platform/api-client": "workspace:*",
    "@agent-management-platform/types": "workspace:*",
    "@agent-management-platform/shared-component": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "24.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.1.9",
    "@typescript-eslint/eslint-plugin": "8.33.1",
    "@typescript-eslint/parser": "8.33.1",
    "eslint": "9.36.0",
    "eslint-config-prettier": "10.1.5",
    "eslint-plugin-prettier": "5.4.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.0",
    "eslint-plugin-storybook": "0.12.0",
    "postcss": "8.5.3",
    "postcss-simple-vars": "7.0.1",
    "prettier": "3.5.3",
    "react": "19.1.1",
    "typescript": "5.9.3",
    "vite": "6.3.5",
    "@vitejs/plugin-react": "5.0.4",
    "vite-plugin-dts": "4.5.4",
    "eslint-import-resolver-typescript": "4.4.1",
    "@eslint/js": "9.36.0",
    "typescript-eslint": "8.45.0",
    "eslint-plugin-import": "2.31.0",
    "globals": "16.4.0",
    "@agent-management-platform/eslint-config": "workspace:*",
    "@eslint/eslintrc": "3.3.1"
  },
  "peerDependencies": {
    "react": "19.1.1"
  }
}
