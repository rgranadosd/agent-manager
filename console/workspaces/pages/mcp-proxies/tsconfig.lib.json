{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "declaration": true,
    "declarationDir": "dist",
    "declarationMap": false,
    "sourceMap": false,
    "baseUrl": ".",
    "ignoreDeprecations": "5.0",
    "paths": {
      "@mcp-proxies/*": ["./src/*"]
    },
    "rootDir": "src"
  },
  "include": ["src/**/*"],
  "exclude": ["src/**/__docs__", "node_modules", "dist"]
}
